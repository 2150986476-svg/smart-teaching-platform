# ============================================================
# AI 智能教学平台 — 环境变量示例
# 复制此文件为 .env 并填入真实值
# ============================================================

PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=ai_teaching_platform

JWT_SECRET=your_jwt_secret_here

# Coze API 访问令牌（从 Coze 控制台获取）
COZE_API_TOKEN=your_coze_api_token_here

# Coze API 基础 URL
COZE_API_BASE_URL=https://api.coze.cn

# Coze API 超时（毫秒）
COZE_API_TIMEOUT=30000
